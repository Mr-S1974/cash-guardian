VITE_CONTACT_EMAIL=you@example.com
# Cloudflare Pages Function will default to /api/contact in production.
# Set this only if you want to override the endpoint.
# VITE_CONTACT_ENDPOINT=https://your-site.pages.dev/api/contact
# Used by scripts/register-telegram-webhook.mjs
CLOUDFLARE_PAGES_URL=https://your-site.pages.dev

# Configure these as Cloudflare Pages production/preview secrets.
TELEGRAM_BOT_TOKEN=123456789:telegram-bot-token
TELEGRAM_CHAT_ID=123456789
TELEGRAM_WEBHOOK_SECRET=replace-with-long-random-secret

# Cloudflare KV binding name reminder. Configure this in Pages as CONTACT_THREADS.
CONTACT_THREADS_KV_BINDING=CONTACT_THREADS
